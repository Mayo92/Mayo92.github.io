    <content type="html"><![CDATA[<h3 id="一、添加多语言资源在Values下"><a href="#一、添加多语言资源在Values下" class="headerlink" title="一、添加多语言资源在Values下"></a>一、添加多语言资源在Values下</h3><h3 id="二、更新Configuration中的locale属性"><a href="#二、更新Configuration中的locale属性" class="headerlink" title="二、更新Configuration中的locale属性"></a>二、更新Configuration中的locale属性</h3><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br></pre></td><td class="code"><pre><span class="line">//更改语言 返回主Activity即IsOpenLocationActivity</span><br><span class="line">Resources resources = LanguageActivity.this.getResources();</span><br><span class="line">DisplayMetrics dm = resources.getDisplayMetrics();</span><br><span class="line">Configuration config = resources.getConfiguration();</span><br><span class="line">// 应用用户选择语言</span><br><span class="line">config.locale = UtilTool.getLanguage();</span><br><span class="line">resources.updateConfiguration(config, dm);</span><br></pre></td></tr></table></figure><a id="more"></a><h3 id="三、重启Activity"><a href="#三、重启Activity" class="headerlink" title="三、重启Activity"></a>三、重启Activity</h3><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><span class="line">Intent intent = new Intent(LanguageActivity.this, IsOpenLocationActivity.class);</span><br><span class="line">intent.setFlags(Intent.FLAG_ACTIVITY_NEW_TASK | Intent.FLAG_ACTIVITY_CLEAR_TASK);</span><br><span class="line">startActivity(intent);</span><br></pre></td></tr></table></figure><h3 id="四、持久化存储"><a href="#四、持久化存储" class="headerlink" title="四、持久化存储"></a>四、持久化存储</h3><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><span class="line">Resources resources = mContext.getResources();</span><br><span class="line">DisplayMetrics dm = resources.getDisplayMetrics();</span><br><span class="line">Configuration config = resources.getConfiguration();</span><br><span class="line">config.locale = UtilTool.getLanguage();</span><br><span class="line">resources.updateConfiguration(config, dm);</span><br></pre></td></tr></table></figure>]]></content>
    
