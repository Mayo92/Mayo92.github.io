      &lt;h3 id=&quot;一、添加多语言资源在Values下&quot;&gt;&lt;a href=&quot;#一、添加多语言资源在Values下&quot; class=&quot;headerlink&quot; title=&quot;一、添加多语言资源在Values下&quot;&gt;&lt;/a&gt;一、添加多语言资源在Values下&lt;/h3&gt;&lt;h3 id=&quot;二、更新Configuration中的locale属性&quot;&gt;&lt;a href=&quot;#二、更新Configuration中的locale属性&quot; class=&quot;headerlink&quot; title=&quot;二、更新Configuration中的locale属性&quot;&gt;&lt;/a&gt;二、更新Configuration中的locale属性&lt;/h3&gt;&lt;figure class=&quot;highlight plain&quot;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&quot;gutter&quot;&gt;&lt;pre&gt;&lt;span class=&quot;line&quot;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;7&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&quot;code&quot;&gt;&lt;pre&gt;&lt;span class=&quot;line&quot;&gt;//更改语言 返回主Activity即IsOpenLocationActivity&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;Resources resources = LanguageActivity.this.getResources();&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;DisplayMetrics dm = resources.getDisplayMetrics();&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;Configuration config = resources.getConfiguration();&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;// 应用用户选择语言&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;config.locale = UtilTool.getLanguage();&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;resources.updateConfiguration(config, dm);&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
    
